student = {
    "name": "Piyush",
    "marks": 90,
    "age": 20
}

print("Original Dictionary:", student)

# Accessing values
print("Name:", student["name"])
print("Marks (using get):", student.get("marks"))

# Adding new key-value
student["city"] = "Mumbai"
print("After adding city:", student)

# Updating value
student["marks"] = 98
print("After updating marks:", student)

# Removing elements
student.pop("age")
print("After removing age:", student)

student.popitem()
print("After popitem:", student)

del student["name"]
print("After deleting name:", student)

student.clear()
print("After clear:", student)

# New dictionaries
d1 = {"a": 1, "b": 2}
d2 = {"b": 3, "c": 4}

print("D1:", d1)
print("D2:", d2)

# Dictionary function
print("Length of d1:", len(d1))

# Nested Dictionary
stu1 = {"name": "Amit", "marks": 88}
stu2 = {"name": "Sneha", "marks": 92}

data = {
    "stu1": stu1,
    "stu2": stu2
}

print("Access nested marks:", data["stu2"]["marks"])

# Merging dictionaries
merged = d1 | d2
print("Merged Dictionary:", merged)
