tup = (5, 15, 25, 35, 45)
print("Original Tuple:", tup)

# Single element tuple
single = (99,)
print("Single Tuple:", single)

# Accessing elements
print("First element:", tup[0])
print("Last element:", tup[-1])

# Slicing
print("First 4 elements:", tup[:4])
print("Middle elements:", tup[1:4])

# Tuple Functions
print("Length:", len(tup))
print("Maximum:", max(tup))
print("Minimum:", min(tup))
print("Sum:", sum(tup))

# Tuple Methods
print("Count of 25:", tup.count(25))
print("Index of 35:", tup.index(35))

# Nested Tuple
nested = ((2, 4, 6), (8, 10, 12))
print("Access nested element:", nested[0][1])
print("Access another element:", nested[1][2])
