s1 = {2, 4, 6, 8}
s2 = {1, 2, 3, 4}

print("Set 1:", s1)
print("Set 2:", s2)

# Adding elements
s1.add(10)
print("After adding one element:", s1)

s1.update([12, 14, 16])
print("After adding multiple elements:", s1)

# Removing elements
s1.remove(12)
print("After removing element:", s1)

s1.discard(100)  # safe remove (no error if not present)
print("After discard:", s1)

s1.pop()
print("After pop:", s1)

# Set Operations
print("Union:", s1.union(s2))
print("Intersection:", s1.intersection(s2))
print("Difference (s1 - s2):", s1.difference(s2))
print("Symmetric Difference:", s1.symmetric_difference(s2))

# Set Functions
print("Length:", len(s1))
print("Maximum:", max(s1))
print("Minimum:", min(s1))
print("Sum:", sum(s1))
