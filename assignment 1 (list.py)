lst = [15, 25, 35, 45, 55]
print("Original List:", lst)

# Accessing elements
print("First element:", lst[0])
print("Last element:", lst[-1])

# Slicing
print("First 3 elements:", lst[:3])
print("Last 2 elements:", lst[-2:])

# Updating list
lst[2] = 100
print("After update:", lst)

# Adding elements
lst.append(200)
print("After append:", lst)

lst.insert(2, 300)
print("After insert:", lst)

# Removing elements
lst.remove(300)
print("After remove:", lst)

lst.pop()
print("After pop last:", lst)

lst.pop(1)
print("After pop index 1:", lst)

# Functions
print("Length:", len(lst))
print("Max:", max(lst))
print("Min:", min(lst))
print("Sum:", sum(lst))

# Sorting
lst.sort()
print("Ascending:", lst)

lst.sort(reverse=True)
print("Descending:", lst)

# Searching
print("Index of 100:", lst.index(100))
print("Count of 15:", lst.count(15))
